# .env.example - exemplo de variáveis de ambiente para deploy no Render
# NÃO coloque valores reais neste arquivo. Use o painel do Render para setar os valores reais.

# === Obrigatórias (app sobe) ===
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/<DB_NAME>
SPRING_DATASOURCE_USERNAME=<db_user>
SPRING_DATASOURCE_PASSWORD=<db_password>
JWT_SECRET=<uma-chave-secreta-com-no-minimo-32-caracteres>

# === Recomendadas / para recursos usados ===
FRONTEND_URL=https://seu-frontend.onrender.com
FRONTEND_RESET_PASSWORD_URL=https://seu-frontend.onrender.com/redefinir-senha
CORS_ALLOWED_ORIGINS=https://seu-frontend.onrender.com,https://outro-dominio.com

# SMTP (opcional - envio de e-mails)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=<seu-email>
SPRING_MAIL_PASSWORD=<sua-senha-app-ou-token>

# Cloudinary (opcional - uploads de imagens)
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_FOLDER=mpfitness/produtos

# Mercado Pago (opcional - pagamentos)
MERCADO_PAGO_ACCESS_TOKEN=<access_token>
MERCADO_PAGO_WEBHOOK_SECRET=<webhook_secret>

# Google OAuth2 (opcional - login social)
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>

# Admin bootstrap (opcional - define conta admin no primeiro boot)
ADMIN_INITIAL_EMAIL=<admin@example.com>
ADMIN_INITIAL_PASSWORD=<senha-segura>

# === Tuning / opcionais ===
JWT_EXPIRATION_MS=36000000
JWT_RESET_EXPIRATION_MS=900000
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# Observações:
# - Render fornece automaticamente a variável PORT.
# - Nunca commitar segredos reais no repo. Use o painel do Render (Environment / Secrets).
# - Para habilitar o bootstrap de admin via env, configure ADMIN_INITIAL_EMAIL e ADMIN_INITIAL_PASSWORD.
